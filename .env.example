# =============================================================================
# WSO2 IS — App-Native Authentication Sample
# =============================================================================
# Copy this file to .env.local and fill in your values.
#
#   cp .env.example .env.local
#
# All configuration is centralised in lib/config.ts which reads from here.
# =============================================================================


# -----------------------------------------------------------------------------
# WSO2 Identity Server
# -----------------------------------------------------------------------------

# Base URL of your WSO2 IS instance (no trailing slash)
NEXT_PUBLIC_ASGARDEO_BASE_URL="https://localhost:9443"

# OAuth2 / OIDC application credentials
# Found in: IS Console → Applications → <your-app> → Protocol tab
NEXT_PUBLIC_ASGARDEO_CLIENT_ID="<your-client-id>"
ASGARDEO_CLIENT_SECRET="<your-client-secret>"

# Secret key used to sign JWT session cookies
# Generate a secure value with: openssl rand -base64 32
ASGARDEO_SECRET="<your-random-secret>"

# Route the SDK uses for the sign-in page (no need to change this)
NEXT_PUBLIC_ASGARDEO_SIGN_IN_URL="/sign-in"


# -----------------------------------------------------------------------------
# IS Admin Credentials
# Used server-side only to call IS account recovery APIs.
# Never exposed to the browser.
# In production, replace with a dedicated service account that has only the
# internal_user_recovery_create permission.
# -----------------------------------------------------------------------------

IS_ADMIN_USERNAME="admin"
IS_ADMIN_PASSWORD="<your-is-admin-password>"


# -----------------------------------------------------------------------------
# Google reCAPTCHA v2
# Used on the Forgot Password page to prevent automated abuse.
# Register your site at: https://www.google.com/recaptcha/admin
# Select: reCAPTCHA v2 → "I'm not a robot" checkbox
#
# For local testing only, Google provides public test keys that always pass:
#   Site key:   6LeIxAcTAAAAAJcZVRqyHh71UMIEGNQ_MXjiZKhI
#   Secret key: 6LeIxAcTAAAAAGG-vFI1TnRWxMZNFuojJ4WifJWe
# Replace with real keys before deploying to any non-localhost environment.
# -----------------------------------------------------------------------------

NEXT_PUBLIC_RECAPTCHA_SITE_KEY="<your-recaptcha-site-key>"
RECAPTCHA_SECRET_KEY="<your-recaptcha-secret-key>"
